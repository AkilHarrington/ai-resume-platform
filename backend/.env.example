# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_ONETIME_PRICE_ID=price_your_onetime_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend URL (used for Stripe redirect)
FRONTEND_URL=http://localhost:5173

# CORS (comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,https://ai-resume-studio.vercel.app

# Supabase (add when ready)
SUPABASE_URL=
# Use a Supabase SECRET key (sb_secret_...) from Settings > API Keys — NOT the legacy service_role JWT.
SUPABASE_SERVICE_KEY=your_supabase_secret_key_here

# Local dev: set to true to bypass the pro gate without Stripe
FORCE_PRO=true
