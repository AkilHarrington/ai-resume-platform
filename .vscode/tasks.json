{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "source .venv/bin/activate && uvicorn main:app --reload --host 127.0.0.1 --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "group": "build",
      "presentation": {
        "group": "servers",
        "panel": "dedicated",
        "reveal": "always",
        "label": "Backend (FastAPI)"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend-app"
      },
      "group": "build",
      "presentation": {
        "group": "servers",
        "panel": "dedicated",
        "reveal": "always",
        "label": "Frontend (Vite)"
      },
      "problemMatcher": []
    },
    {
      "label": "Start All (Backend + Frontend)",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
